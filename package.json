{
  "name": "smruti-cortex",
  "version": "9.5.0",
  "private": true,
  "description": "SmrutiCortex — Everything-like instant browser history search (MV3).",
  "homepage": "https://dhruvinrsoni.github.io/smruti-cortex/",
  "chromeStoreUrl": "https://chromewebstore.google.com/detail/ecnkiihcifbfnhjblicfbppplobiicoi",
  "repository": {
    "type": "git",
    "url": "https://github.com/dhruvinrsoni/smruti-cortex.git"
  },
  "author": "dhruvinrsoni",
  "bugs": {
    "url": "https://github.com/dhruvinrsoni/smruti-cortex/issues"
  },
  "keywords": [
    "chrome-extension",
    "mv3",
    "history",
    "search",
    "privacy",
    "smruti-cortex"
  ],
  "license": "BUSL-1.1",
  "scripts": {
    "build": "node ./scripts/sync-version.mjs && rimraf dist && tsc --project tsconfig.json && node ./scripts/copy-static.mjs && node ./scripts/esbuild-prod.mjs",
    "package": "npm run build && node ./scripts/package.mjs",
    "ship": "node ./scripts/release.mjs",
    "store": "node ./scripts/store.mjs",
    "lint": "node ./scripts/lint.mjs",
    "test": "node ./scripts/test.mjs",
    "coverage": "vitest run --coverage",
    "e2e": "npm run build && npx playwright test",
    "verify": "node ./scripts/verify.mjs",
    "dashboard": "node ./scripts/dashboard.mjs",
    "dev": "node ./scripts/esbuild-dev.mjs --watch",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/chrome": "^0.0.188",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.16",
    "archiver": "^7.0.1",
    "esbuild": "^0.27.0",
    "eslint": "^8.57.0",
    "husky": "^9.1.7",
    "jsdom": "^24.1.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.16"
  }
}
